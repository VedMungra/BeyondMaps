PORT=5000
MONGO_URI=mongodb://localhost:27017/travel-agency
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRE=30d
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
FROM_EMAIL=noreply@travelagency.com
FROM_NAME=BeyondMaps

# Required to enable POST /api/v1/auth/register (admin account creation).
# Generate one with: node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
# Registration is refused entirely if this is unset.
ADMIN_REGISTER_KEY=your_admin_registration_key_here

# Optional. If unset, tour photo/gallery uploads fall back to local disk storage
# (backend/public/uploads) instead of Cloudinary.
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
